<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity"
    android:background="@color/white">

    <TextureView
        android:id="@+id/viewFinder"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="0dp"
        android:layout_marginBottom="0dp"
        app:layout_constraintDimensionRatio="W,4:3"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:layout_editor_absoluteX="365dp"
        tools:layout_editor_absoluteY="0dp">


    </TextureView>
    <com.kuroda33.acapnys.MyView
        android:id="@+id/myView"
        android:layout_width="90dp"
        android:layout_height="90dp"
        android:layout_marginStart="0dp"
        android:layout_marginTop="0dp"
        app:layout_constraintStart_toStartOf="@id/viewFinder"
        app:layout_constraintTop_toTopOf="@id/viewFinder" />

    <ImageButton
        android:id="@+id/lastThumbnail"
        android:layout_width="70dp"
        android:layout_height="0dp"
        android:layout_margin="8dp"
        android:background="@android:drawable/editbox_background_normal"
        android:clipToOutline="true"
        android:outlineProvider="background"
        android:scaleType="centerCrop"
        app:layout_constraintDimensionRatio="4:3"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/elapsedTimeText"
        android:layout_width="70dp"
        android:layout_height="0dp"
        android:layout_margin="8dp"
        android:gravity="center"
        android:text="00:00"
        android:textColor="@android:color/black"
        android:textStyle="bold"
        android:textSize="18sp"
        android:visibility="gone"
        app:layout_constraintDimensionRatio="4:3"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/listButton"
        android:layout_width="70dp"
        android:layout_height="50dp"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="8dp"
        android:background="@android:drawable/editbox_background_normal"
        android:backgroundTint="@color/design_default_color_primary"
        android:src="@android:drawable/ic_menu_sort_by_size"
        app:tint="@android:color/white"
        android:contentDescription="list"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/lastThumbnail" />

    <SeekBar
        android:id="@+id/zoomSeekBar"
        style="@style/Base.Theme.ACapNYS"
        android:layout_width="0dp"
        android:layout_height="40dp"
        android:layout_marginStart="2dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="12dp"
        android:background="#ccc"
        android:clickable="true"
        android:progressTint="@color/design_default_color_primary"
        android:thumbTint="@color/design_default_color_primary"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@+id/zoomText"
        app:layout_constraintEnd_toStartOf="@+id/focusText" />

    <ImageButton
        android:id="@+id/recordButton"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:layout_marginEnd="8dp"
        android:alpha="1.0"
        android:background="@drawable/record_button_bg"
        android:contentDescription="record"
        android:padding="0dp"
        android:src="@drawable/record1"
        android:scaleType="fitXY"
        app:tint="@color/white"
        app:layout_constraintTop_toBottomOf="@id/listButton"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/helpButton"
        app:layout_constraintVertical_bias="0.5" />

    <EditText
        android:id="@+id/focusText"
        android:layout_width="80dp"
        android:layout_height="50dp"
        android:layout_marginStart="8dp"
        android:layout_marginBottom="8dp"
        android:paddingRight="0dp"
        android:paddingLeft="0dp"
        android:background="@android:drawable/editbox_background_normal"
        android:textColor="@color/black"
        android:text="Focus"
        android:textSize="20sp"
        android:textAlignment="center"
        android:focusableInTouchMode="false"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <SeekBar
        android:id="@+id/focusSeekBar"
        style="@style/Base.Theme.ACapNYS"
        android:layout_width="0dp"
        android:layout_height="40dp"
        android:layout_marginStart="2dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="12dp"
        android:background="#ccc"
        android:clickable="true"
        android:progressTint="@color/design_default_color_primary"
        android:thumbTint="@color/design_default_color_primary"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@+id/focusText"
        app:layout_constraintEnd_toStartOf="@+id/cameraButton" />

    <EditText
        android:id="@+id/zoomText"
        android:layout_width="80dp"
        android:layout_height="50dp"
        android:layout_marginStart="8dp"
        android:layout_marginBottom="8dp"
        android:text="Zoom"
        android:textSize="20sp"
        android:textAlignment="center"
        android:focusableInTouchMode="false"
        android:background="@android:drawable/editbox_background_normal"
        android:textColor="@color/black"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />
    <ImageButton
        android:id="@+id/helpButton"
        android:layout_width="70dp"
        android:layout_height="50dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="4dp"
        android:background="@android:drawable/editbox_background_normal"
        android:backgroundTint="@color/design_default_color_primary"
        android:contentDescription="NULL"
        android:src="@drawable/help"
        app:tint="@color/white"
        app:layout_constraintBottom_toTopOf="@id/cameraButton"
        app:layout_constraintEnd_toEndOf="parent" />

    <ImageButton
        android:id="@+id/cameraButton"
        android:layout_width="70dp"
        android:layout_height="50dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="8dp"
        android:background="@android:drawable/editbox_background_normal"
        android:backgroundTint="@color/design_default_color_primary"
        android:src="@drawable/camera"
        app:tint="@color/white"
        android:contentDescription="NULL"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/cameraToastText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:background="#AA000000"
        android:paddingLeft="8dp"
        android:paddingTop="4dp"
        android:paddingRight="8dp"
        android:paddingBottom="4dp"
        android:textColor="@android:color/white"
        android:textSize="14sp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/cameraButton"
        app:layout_constraintEnd_toEndOf="@id/cameraButton" />
</androidx.constraintlayout.widget.ConstraintLayout>
