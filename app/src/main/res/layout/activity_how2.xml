<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".How2Activity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:layout_margin="8dp"
                    android:src="@drawable/sougu" />

                <TextView
                    android:id="@+id/textView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="30dp"
                    android:layout_marginEnd="30dp"
                    android:gravity="start"
                    android:textAlignment="viewStart"
                    android:text="@string/eng_text"
                    android:textSize="19sp" />
            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_margin="16dp"
        android:background="@drawable/bg_back_circle"
        android:backgroundTint="@color/design_default_color_primary"
        android:contentDescription="back"
        android:padding="10dp"
        android:src="@drawable/ic_left_triangle"
        android:tint="#FFFFFF"
        android:layout_gravity="bottom|end" />

    <ImageButton
        android:id="@+id/btnGyro"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_margin="16dp"
        android:background="@drawable/bg_back_circle"
        android:backgroundTint="@color/design_default_color_primary"
        android:contentDescription="gyro"
        android:padding="10dp"
        android:src="@android:drawable/ic_menu_compass"
        android:tint="#FFFFFF"
        android:layout_gravity="bottom|start" />

</FrameLayout>
